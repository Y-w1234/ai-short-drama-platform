# DeepSeek API Key (在 https://platform.deepseek.com 注册获取)
DEEPSEEK_API_KEY=sk-your-key-here

# 豆包 API Key (在火山引擎控制台获取)
DOUBAO_API_KEY=your-doubao-key

# LLM 选择: deepseek / doubao
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat

# 图片/视频生成 (可选)
IMAGE_API_KEY=
VIDEO_API_KEY=

# 数据库
DATABASE_URL=sqlite:///data/drama.db

# LLM API 地址（留空默认 DeepSeek 官方；可改为兼容代理地址）
LLM_BASE_URL=

# 图片生成服务商: jimeng / tongyi
IMAGE_PROVIDER=jimeng

# 视频生成服务商: jimeng
VIDEO_PROVIDER=jimeng

# 调试模式
DEBUG=false
